# Copy this file to .env (local dev) and set this to your backend's URL.
# Local backend:
VITE_API_URL=http://localhost:5050/api

# When deployed (e.g. on Vercel), set VITE_API_URL as a Project Environment
# Variable pointing at your deployed backend, e.g.:
# VITE_API_URL=https://oris-backend.onrender.com/api
