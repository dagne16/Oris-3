# Server
PORT=5050
NODE_ENV=development

# Database - Local MongoDB
MONGODB_URI=mongodb://localhost:27017/oris_store

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Frontend URL(s) allowed to call this API (CORS). Comma-separate multiple origins,
# e.g. when you deploy: http://localhost:5173,https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173